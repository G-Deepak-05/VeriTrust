# =============================================================================
# VeriTrust — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_NAME=VeriTrust
APP_VERSION=0.1.0
API_PREFIX=/api/v1

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=supersecretkey-change-in-production-min-32chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://veritrust:veritrust@localhost:5432/veritrust
# For Docker: DATABASE_URL=postgresql+asyncpg://veritrust:veritrust@postgres:5432/veritrust
POSTGRES_USER=veritrust
POSTGRES_PASSWORD=veritrust
POSTGRES_DB=veritrust

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# For Docker: REDIS_URL=redis://redis:6379/0

# ─── Celery ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# For Docker: redis://redis:6379/1 and redis://redis:6379/2

# ─── LocalStack / AWS ────────────────────────────────────────────────────────
AWS_ENDPOINT_URL=http://localhost:4566
# For Docker: http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=veritrust-docs

# ─── Mailpit / Email ─────────────────────────────────────────────────────────
MAILPIT_HOST=localhost
MAILPIT_PORT=1025
# For Docker: MAILPIT_HOST=mailpit
EMAIL_FROM=noreply@veritrust.local
EMAIL_FROM_NAME=VeriTrust

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ─── Monitoring ──────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true

# ─── LocalStack Auth (Pro features, leave empty for Community) ───────────────
LOCALSTACK_AUTH_TOKEN=

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
